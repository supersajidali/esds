     "text": [
      "\n",
      "# =============================================================================\n",
      "#  Pickle Save/Load for Email Spam Detection Model\n",
      "#  Prepared By: Sajid Ali\n",
      "# =============================================================================\n",
      "# Add these functions to your email_spam_detection.py or use standalone\n",
      "# =============================================================================\n",
      "\n",
      "import pickle\n",
      "import os\n",
      "from pathlib import Path\n",
      "\n",
      "# ── Configuration ─────────────────────────────────────────────────────────────\n",
      "MODEL_PATH = \"spam_classifier_pipeline.pkl\"  # Path to save/load the model\n",
      "\n",
      "\n",
      "# =============================================================================\n",
      "# SAVE MODEL TO DISK\n",
      "# =============================================================================\n",
      "def save_model(pipeline, filepath: str = MODEL_PATH) -> None:\n",
      "    \"\"\"\n",
      "    Save the trained pipeline to a pickle file.\n",
      "    \n",
      "    Args:\n",
      "        pipeline: Trained sklearn Pipeline object\n",
      "        filepath: Path where to save the model (default: \"spam_classifier_pipeline.pkl\")\n",
      "    \"\"\"\n",
      "    try:\n",
      "        with open(filepath, 'wb') as file:\n",
      "            pickle.dump(pipeline, file)\n",
      "        print(f\"✅ Model saved successfully to: {filepath}\")\n",
      "        print(f\"   File size: {os.path.getsize(filepath) / 1024:.2f} KB\")\n",
      "    except Exception as e:\n",
      "        print(f\"❌ Error saving model: {e}\")\n",
      "\n",
      "\n",
      "# =============================================================================\n",
      "# LOAD MODEL FROM DISK\n",
      "# =============================================================================\n",
      "def load_model(filepath: str = MODEL_PATH):\n",
      "    \"\"\"\n",
      "    Load a trained pipeline from a pickle file.\n",
      "    \n",
      "    Args:\n",
      "        filepath: Path to the saved model file\n",
      "        \n",
      "    Returns:\n",
      "        Loaded pipeline object ready for prediction\n",
      "    \"\"\"\n",
      "    try:\n",
      "        with open(filepath, 'rb') as file:\n",
      "            pipeline = pickle.load(file)\n",
      "        print(f\"✅ Model loaded successfully from: {filepath}\")\n",
      "        return pipeline\n",
      "    except FileNotFoundError:\n",
      "        print(f\"❌ Model file not found: {filepath}\")\n",
      "        print(\"   Please train and save the model first.\")\n",
      "        return None\n",
      "    except Exception as e:\n",
      "        print(f\"❌ Error loading model: {e}\")\n",
      "        return None\n",
      "\n",
      "\n",
      "# =============================================================================\n",
      "# EXAMPLE USAGE (Add to your main() function)\n",
      "# =============================================================================\n",
      "\n",
      "def main_with_pickle():\n",
      "    \"\"\"\n",
      "    Example of how to integrate pickle save/load into your workflow.\n",
      "    \"\"\"\n",
      "    # Check if model already exists\n",
      "    if os.path.exists(MODEL_PATH):\n",
      "        print(\"\\n📂 Existing model found. Loading from disk...\")\n",
      "        pipeline = load_model(MODEL_PATH)\n",
      "        \n",
      "        # Optional: Load test data for evaluation\n",
      "        df = load_data(CSV_PATH)\n",
      "        df = preprocess(df)\n",
      "        X_train, X_test, y_train, y_test = split_data(df)\n",
      "        \n",
      "    else:\n",
      "        print(\"\\n🔧 No saved model found. Training new model...\")\n",
      "        \n",
      "        # 1. Load & preprocess data\n",
      "        df = load_data(CSV_PATH)\n",
      "        run_eda(df)\n",
      "        df = preprocess(df)\n",
      "        X_train, X_test, y_train, y_test = split_data(df)\n",
      "        \n",
      "        # 2. Build & train pipeline\n",
      "        pipeline = build_pipeline()\n",
      "        cross_validate(pipeline, X_train, y_train)\n",
      "        pipeline = train_model(pipeline, X_train, y_train)\n",
      "        \n",
      "        # 3. Evaluate\n",
      "        y_pred, y_pred_prob, roc_auc = evaluate(pipeline, X_test, y_test)\n",
      "        plot_evaluation(y_test, y_pred, y_pred_prob, roc_auc)\n",
      "        plot_keywords(pipeline)\n",
      "        \n",
      "        # 4. 💾 SAVE THE MODEL\n",
      "        save_model(pipeline, MODEL_PATH)\n",
      "    \n",
      "    # 5. Make predictions (works with loaded or newly trained model)\n",
      "    predict_samples(pipeline)\n",
      "    predict_custom(pipeline)\n",
      "\n",
      "\n",
      "# =============================================================================\n",
      "# QUICK PREDICTION FUNCTION (using saved model)\n",
      "# =============================================================================\n",
      "\n",
      "def quick_predict(email_text: str, model_path: str = MODEL_PATH) -> dict:\n",
      "    \"\"\"\n",
      "    Quick prediction function that loads model and predicts on new text.\n",
      "    Perfect for API or web app integration.\n",
      "    \n",
      "    Args:\n",
      "        email_text: Raw email text to classify\n",
      "        model_path: Path to saved model\n",
      "        \n",
      "    Returns:\n",
      "        Dictionary with prediction results\n",
      "    \"\"\"\n",
      "    # Load model (you might want to load once and reuse in production)\n",
      "    pipeline = load_model(model_path)\n",
      "    if pipeline is None:\n",
      "        return {\"error\": \"Model not found\"}\n",
      "    \n",
      "    # Clean and predict\n",
      "    cleaned = clean_text(email_text)\n",
      "    pred = pipeline.predict([cleaned])[0]\n",
      "    prob = pipeline.predict_proba([cleaned])[0][1]\n",
      "    \n",
      "    return {\n",
      "        \"text\": email_text[:100] + \"...\" if len(email_text) > 100 else email_text,\n",
      "        \"prediction\": \"SPAM\" if pred == 1 else \"HAM\",\n",
      "        \"spam_probability\": float(prob),\n",
      "        \"ham_probability\": float(1 - prob),\n",
      "        \"confidence\": f\"{max(prob, 1-prob)*100:.1f}%\"\n",
      "    }\n",
      "\n",
      "\n",
      "# =============================================================================\n",
      "# STREAMLIT INTEGRATION (add to app.py)\n",
      "# =============================================================================\n",
      "\"\"\"\n",
      "# At the top of app.py, add:\n",
      "import pickle\n",
      "\n",
      "# Replace the train_pipeline function with cached loader:\n",
      "@st.cache_resource(show_spinner=\"🔧 Loading model…\")\n",
      "def load_or_train_model(df: pd.DataFrame, model_path: str = \"spam_classifier_pipeline.pkl\"):\n",
      "    \"\"\"Load existing model or train new one if not exists.\"\"\"\n",
      "    \n",
      "    if os.path.exists(model_path):\n",
      "        with open(model_path, 'rb') as f:\n",
      "            pipeline = pickle.load(f)\n",
      "        return pipeline, None, None, None, None, None, None, None, None\n",
      "    \n",
      "    # Otherwise train (your existing train_pipeline code)\n",
      "    ...\n",
      "    \n",
      "    # Save after training\n",
      "    with open(model_path, 'wb') as f:\n",
      "        pickle.dump(pipeline, f)\n",
      "    \n",
      "    return pipeline, df, X_train, X_test, y_train, y_test, y_pred, y_pred_prob, cv_f1\n",
      "\n",
      "# Add a button to download the model:\n",
      "with st.sidebar:\n",
      "    if os.path.exists(\"spam_classifier_pipeline.pkl\"):\n",
      "        with open(\"spam_classifier_pipeline.pkl\", \"rb\") as f:\n",
      "            st.download_button(\n",
      "                label=\"⬇️ Download Trained Model\",\n",
      "                data=f,\n",
      "                file_name=\"spam_classifier_pipeline.pkl\",\n",
      "                mime=\"application/octet-stream\"\n",
      "            )\n",
      "\"\"\"\n",
      "\n",
      "\n",
      "# =============================================================================\n",
      "# JOBlib ALTERNATIVE (More efficient for large numpy arrays)\n",
      "# =============================================================================\n",
      "\"\"\"\n",
      "For better performance with large models, use joblib instead of pickle:\n",
      "\n",
      "from joblib import dump, load\n",
      "\n",
      "def save_model_joblib(pipeline, filepath: str = \"spam_classifier_pipeline.joblib\"):\n",
      "    dump(pipeline, filepath)\n",
      "    print(f\"✅ Model saved with joblib: {filepath}\")\n",
      "\n",
      "def load_model_joblib(filepath: str = \"spam_classifier_pipeline.joblib\"):\n",
      "    pipeline = load(filepath)\n",
      "    print(f\"✅ Model loaded with joblib: {filepath}\")\n",
      "    return pipeline\n",
      "\n",
      "# joblib is recommended for sklearn models as it's more efficient\n",
      "# Install: pip install joblib\n",
      "\"\"\"\n",
      "\n",
      "\n",
      "if __name__ == \"__main__\":\n",
      "    print(\"=\" * 60)\n",
      "    print(\"  Pickle Utilities for Email Spam Detection\")\n",
      "    print(\"=\" * 60)\n",
      "    print(\"\\nAvailable functions:\")\n",
      "    print(\"  • save_model(pipeline, filepath)     - Save trained model\")\n",
      "    print(\"  • load_model(filepath)               - Load saved model\")\n",
      "    print(\"  • quick_predict(text, model_path)    - Predict on new email\")\n",
      "    print(\"  • main_with_pickle()                 - Full workflow with save/load\")\n",
      "    print(\"\\nUsage:\")\n",
      "    print(\"  from email_spam_detection import *\")\n",
      "    print(\"  # After training:\")\n",
      "    print(\"  save_model(pipeline)\")\n",
      "    print(\"  # Later:\")\n",
      "    print(\"  pipeline = load_model()\")\n",
      "    print(\"  prediction = pipeline.predict([clean_text(email)])\")\n",
      "\n"
     ]
    }
   ],
   "source": [
    "\n",
    "pickle_code = '''\n",
    "# =============================================================================\n",
    "#  Pickle Save/Load for Email Spam Detection Model\n",
    "#  Prepared By: Sajid Ali\n",
    "# =============================================================================\n",
    "# Add these functions to your email_spam_detection.py or use standalone\n",
    "# =============================================================================\n",
    "\n",
    "import pickle\n",
    "import os\n",
    "from pathlib import Path\n",
    "\n",
    "# ── Configuration ─────────────────────────────────────────────────────────────\n",
    "MODEL_PATH = \"spam_classifier_pipeline.pkl\"  # Path to save/load the model\n",
    "\n",
    "\n",
    "# =============================================================================\n",
    "# SAVE MODEL TO DISK\n",
    "# =============================================================================\n",
    "def save_model(pipeline, filepath: str = MODEL_PATH) -> None:\n",
    "    \"\"\"\n",
    "    Save the trained pipeline to a pickle file.\n",
    "    \n",
    "    Args:\n",
    "        pipeline: Trained sklearn Pipeline object\n",
    "        filepath: Path where to save the model (default: \"spam_classifier_pipeline.pkl\")\n",
    "    \"\"\"\n",
    "    try:\n",
    "        with open(filepath, 'wb') as file:\n",
    "            pickle.dump(pipeline, file)\n",
    "        print(f\"✅ Model saved successfully to: {filepath}\")\n",
    "        print(f\"   File size: {os.path.getsize(filepath) / 1024:.2f} KB\")\n",
    "    except Exception as e:\n",
    "        print(f\"❌ Error saving model: {e}\")\n",
    "\n",
    "\n",
    "# =============================================================================\n",
    "# LOAD MODEL FROM DISK\n",
    "# =============================================================================\n",
    "def load_model(filepath: str = MODEL_PATH):\n",
    "    \"\"\"\n",
    "    Load a trained pipeline from a pickle file.\n",
    "    \n",
    "    Args:\n",
    "        filepath: Path to the saved model file\n",
    "        \n",
    "    Returns:\n",
    "        Loaded pipeline object ready for prediction\n",
    "    \"\"\"\n",
    "    try:\n",
    "        with open(filepath, 'rb') as file:\n",
    "            pipeline = pickle.load(file)\n",
    "        print(f\"✅ Model loaded successfully from: {filepath}\")\n",
    "        return pipeline\n",
    "    except FileNotFoundError:\n",
    "        print(f\"❌ Model file not found: {filepath}\")\n",
    "        print(\"   Please train and save the model first.\")\n",
    "        return None\n",
    "    except Exception as e:\n",
    "        print(f\"❌ Error loading model: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "# =============================================================================\n",
    "# EXAMPLE USAGE (Add to your main() function)\n",
    "# =============================================================================\n",
    "\n",
    "def main_with_pickle():\n",
    "    \"\"\"\n",
    "    Example of how to integrate pickle save/load into your workflow.\n",
    "    \"\"\"\n",
    "    # Check if model already exists\n",
    "    if os.path.exists(MODEL_PATH):\n",
    "        print(\"\\\\n📂 Existing model found. Loading from disk...\")\n",
    "        pipeline = load_model(MODEL_PATH)\n",
    "        \n",
    "        # Optional: Load test data for evaluation\n",
    "        df = load_data(CSV_PATH)\n",
    "        df = preprocess(df)\n",
    "        X_train, X_test, y_train, y_test = split_data(df)\n",
    "        \n",
    "    else:\n",
    "        print(\"\\\\n🔧 No saved model found. Training new model...\")\n",
    "        \n",
    "        # 1. Load & preprocess data\n",
    "        df = load_data(CSV_PATH)\n",
    "        run_eda(df)\n",
    "        df = preprocess(df)\n",
    "        X_train, X_test, y_train, y_test = split_data(df)\n",
    "        \n",
    "        # 2. Build & train pipeline\n",
    "        pipeline = build_pipeline()\n",
    "        cross_validate(pipeline, X_train, y_train)\n",
    "        pipeline = train_model(pipeline, X_train, y_train)\n",
    "        \n",
    "        # 3. Evaluate\n",
    "        y_pred, y_pred_prob, roc_auc = evaluate(pipeline, X_test, y_test)\n",
    "        plot_evaluation(y_test, y_pred, y_pred_prob, roc_auc)\n",
    "        plot_keywords(pipeline)\n",
    "        \n",
    "        # 4. 💾 SAVE THE MODEL\n",
    "        save_model(pipeline, MODEL_PATH)\n",
    "    \n",
    "    # 5. Make predictions (works with loaded or newly trained model)\n",
    "    predict_samples(pipeline)\n",
    "    predict_custom(pipeline)\n",
    "\n",
    "\n",
    "# =============================================================================\n",
    "# QUICK PREDICTION FUNCTION (using saved model)\n",
    "# =============================================================================\n",
    "\n",
    "def quick_predict(email_text: str, model_path: str = MODEL_PATH) -> dict:\n",
    "    \"\"\"\n",
    "    Quick prediction function that loads model and predicts on new text.\n",
    "    Perfect for API or web app integration.\n",
    "    \n",
    "    Args:\n",
    "        email_text: Raw email text to classify\n",
    "        model_path: Path to saved model\n",
    "        \n",
    "    Returns:\n",
    "        Dictionary with prediction results\n",
    "    \"\"\"\n",
    "    # Load model (you might want to load once and reuse in production)\n",
    "    pipeline = load_model(model_path)\n",
    "    if pipeline is None:\n",
    "        return {\"error\": \"Model not found\"}\n",
    "    \n",
    "    # Clean and predict\n",
    "    cleaned = clean_text(email_text)\n",
    "    pred = pipeline.predict([cleaned])[0]\n",
    "    prob = pipeline.predict_proba([cleaned])[0][1]\n",
    "    \n",
    "    return {\n",
    "        \"text\": email_text[:100] + \"...\" if len(email_text) > 100 else email_text,\n",
    "        \"prediction\": \"SPAM\" if pred == 1 else \"HAM\",\n",
    "        \"spam_probability\": float(prob),\n",
    "        \"ham_probability\": float(1 - prob),\n",
    "        \"confidence\": f\"{max(prob, 1-prob)*100:.1f}%\"\n",
    "    }\n",
    "\n",
    "\n",
    "# =============================================================================\n",
    "# STREAMLIT INTEGRATION (add to app.py)\n",
    "# =============================================================================\n",
    "\"\"\"\n",
    "# At the top of app.py, add:\n",
    "import pickle\n",
    "\n",
    "# Replace the train_pipeline function with cached loader:\n",
    "@st.cache_resource(show_spinner=\"🔧 Loading model…\")\n",
    "def load_or_train_model(df: pd.DataFrame, model_path: str = \"spam_classifier_pipeline.pkl\"):\n",
    "    \\\"\\\"\\\"Load existing model or train new one if not exists.\\\"\\\"\\\"\n",
    "    \n",
    "    if os.path.exists(model_path):\n",
    "        with open(model_path, 'rb') as f:\n",
    "            pipeline = pickle.load(f)\n",
    "        return pipeline, None, None, None, None, None, None, None, None\n",
    "    \n",
    "    # Otherwise train (your existing train_pipeline code)\n",
    "    ...\n",
    "    \n",
    "    # Save after training\n",
    "    with open(model_path, 'wb') as f:\n",
    "        pickle.dump(pipeline, f)\n",
    "    \n",
    "    return pipeline, df, X_train, X_test, y_train, y_test, y_pred, y_pred_prob, cv_f1\n",
    "\n",
    "# Add a button to download the model:\n",
    "with st.sidebar:\n",
    "    if os.path.exists(\"spam_classifier_pipeline.pkl\"):\n",
    "        with open(\"spam_classifier_pipeline.pkl\", \"rb\") as f:\n",
    "            st.download_button(\n",
    "                label=\"⬇️ Download Trained Model\",\n",
    "                data=f,\n",
    "                file_name=\"spam_classifier_pipeline.pkl\",\n",
    "                mime=\"application/octet-stream\"\n",
    "            )\n",
    "\"\"\"\n",
    "\n",
    "\n",
    "# =============================================================================\n",
    "# JOBlib ALTERNATIVE (More efficient for large numpy arrays)\n",
    "# =============================================================================\n",
    "\"\"\"\n",
    "For better performance with large models, use joblib instead of pickle:\n",
    "\n",
    "from joblib import dump, load\n",
    "\n",
    "def save_model_joblib(pipeline, filepath: str = \"spam_classifier_pipeline.joblib\"):\n",
    "    dump(pipeline, filepath)\n",
    "    print(f\"✅ Model saved with joblib: {filepath}\")\n",
    "\n",
    "def load_model_joblib(filepath: str = \"spam_classifier_pipeline.joblib\"):\n",
    "    pipeline = load(filepath)\n",
    "    print(f\"✅ Model loaded with joblib: {filepath}\")\n",
    "    return pipeline\n",
    "\n",
    "# joblib is recommended for sklearn models as it's more efficient\n",
    "# Install: pip install joblib\n",
    "\"\"\"\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    print(\"=\" * 60)\n",
    "    print(\"  Pickle Utilities for Email Spam Detection\")\n",
    "    print(\"=\" * 60)\n",
    "    print(\"\\\\nAvailable functions:\")\n",
    "    print(\"  • save_model(pipeline, filepath)     - Save trained model\")\n",
    "    print(\"  • load_model(filepath)               - Load saved model\")\n",
    "    print(\"  • quick_predict(text, model_path)    - Predict on new email\")\n",
    "    print(\"  • main_with_pickle()                 - Full workflow with save/load\")\n",
    "    print(\"\\\\nUsage:\")\n",
    "    print(\"  from email_spam_detection import *\")\n",
    "    print(\"  # After training:\")\n",
    "    print(\"  save_model(pipeline)\")\n",
    "    print(\"  # Later:\")\n",
    "    print(\"  pipeline = load_model()\")\n",
    "    print(\"  prediction = pipeline.predict([clean_text(email)])\")\n",
    "'''\n",
    "\n",
    "print(pickle_code)\n"
   ]
